{
  "compilerOptions": {
    "target": "es2019",
    "module": "Node16",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "lib": ["ES2019", "DOM"],
    "types": ["node"]
  },
  "include": ["**/*"]
}